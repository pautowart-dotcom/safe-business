PORT=4000
DATABASE_URL=postgres://safebiz:changeme@localhost:5432/safe_business
JWT_SECRET=change_this_to_a_long_random_string
# 32-байтный ключ (64 hex-символа) для шифрования данных аудита
# безопасности (core/crypto.js). Сгенерировать:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECURITY_ENCRYPTION_KEY=change_this_to_a_64_char_hex_string
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Учётные данные первого владельца, создаваемые скриптом `npm run seed`
SEED_OWNER_NAME=Владелец
SEED_OWNER_EMAIL=owner@example.com
SEED_OWNER_PASSWORD=change_me_123
