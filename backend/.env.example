PORT=4000
DATABASE_URL=postgres://safebiz:changeme@localhost:5432/safe_business
JWT_SECRET=change_this_to_a_long_random_string
# 32-байтный ключ (64 hex-символа) для шифрования данных аудита
# безопасности (core/crypto.js). Сгенерировать:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECURITY_ENCRYPTION_KEY=change_this_to_a_64_char_hex_string
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Push-уведомления (Пакет 3, Этап 9, Web Push API). Без этих двух ключей
# core/pushNotify.js молча не отправляет push (не роняет остальной код) —
# сгенерировать пару:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@safe-business.local

# Учётные данные первого владельца, создаваемые скриптом `npm run seed`
SEED_OWNER_NAME=Владелец
SEED_OWNER_EMAIL=owner@example.com
SEED_OWNER_PASSWORD=change_me_123

# Автопроверка после деплоя (Задача 0, backend/src/scripts/smokeCheck.js) —
# отдельная служебная компания, не пересекается с реальными клиентами.
# Создаётся один раз скриптом `node src/db/seedSmokeTest.js` (deploy.sh
# запускает его автоматически). SMOKE_APP_URL — адрес, по которому
# автопроверка стучится сама в себя после деплоя (по умолчанию localhost).
SMOKE_APP_URL=http://localhost
SMOKE_OWNER_EMAIL=smoke-owner@example.com
SMOKE_OWNER_PASSWORD=change_me_smoke_owner
SMOKE_ADMIN_EMAIL=smoke-admin@example.com
SMOKE_ADMIN_PASSWORD=change_me_smoke_admin
SMOKE_MASTER_EMAIL=smoke-master@example.com
SMOKE_MASTER_PASSWORD=change_me_smoke_master
